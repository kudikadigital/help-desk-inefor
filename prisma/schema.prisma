// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  phone           String
  paymentProofUrl String?
  status          String   @default("NOVO") // NOVO, AGUARDANDO_VALIDACAO, MATRICULADO
  createdAt       DateTime @default(now())
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

// Adicione isto ao seu arquivo schema.prisma existente

model Batch {
  id               String   @id @default(cuid())
  name             String
  price            Float    // Preço Base (Ex: 175000)
  discount         Int      // Porcentagem de desconto (Ex: 50)
  installmentPrice Float    @default(0) // Valor da parcela (Ex: 45000)
  slots            Int      // Vagas disponíveis
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  order            Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Payment {
  id                    String    @id @default(cuid())
  // Lote
  batchId               String
  batchName             String
  // Valor
  amount                Int
  currency              String    @default("AOA")
  // AppyPay
  appypayChargeId       String?
  merchantTransactionId String    @unique
  paymentMethod         String    // "GPO" | "REF"
  status                String    @default("pending") // pending | paid | failed | expired
  // REF
  referenceNumber       String?
  referenceEntity       String?
  expiresAt             DateTime?
  // Cliente
  fullName              String
  email                 String
  phone                 String
  phoneNumber           String?
  // Datas
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}